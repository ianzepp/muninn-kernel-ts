{
  "name": "muninn-kernel-ts",
  "version": "0.1.0",
  "description": "Transport-agnostic microkernel for in-memory Muninn frame routing in TypeScript",
  "license": "MIT",
  "author": "Ian Zepp",
  "repository": {
    "type": "git",
    "url": "https://github.com/ianzepp/muninn-kernel-ts.git"
  },
  "homepage": "https://github.com/ianzepp/muninn-kernel-ts",
  "bugs": {
    "url": "https://github.com/ianzepp/muninn-kernel-ts/issues"
  },
  "keywords": [
    "muninn",
    "kernel",
    "routing",
    "frames",
    "async"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node --test dist/**/*_test.js"
  },
  "dependencies": {
    "muninn-frames-ts": "file:../muninn-frames-ts"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2"
  }
}
